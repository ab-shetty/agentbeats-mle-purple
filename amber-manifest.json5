// Amber manifest for the MLE-Bench purple agent.
//
// The image must be pullable from GHCR by the quick-submit workflow.
// Pin to an immutable digest at submission time, e.g.:
//   ghcr.io/<YOUR_GHCR_USER>/mle-bench-purple@sha256:<DIGEST>
{
  manifest_version: "0.2.0",
  program: {
    // After the publish workflow runs, replace this with the digest form:
    //   ghcr.io/ab-shetty/agentbeats-mle-purple@sha256:<DIGEST>
    // The workflow prints the pinned reference in its job summary.
    image: "ghcr.io/ab-shetty/agentbeats-mle-purple:latest",
    entrypoint: [
      "python", "-m", "src.server",
      "--host", "0.0.0.0",
      "--port", "8080",
    ],
    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      OPENAI_MODEL: { when: "config.openai_model", value: "${config.openai_model}" },
      REASONING_EFFORT: { when: "config.reasoning_effort", value: "${config.reasoning_effort}" },
      MAX_DEBUG_ITERS: { when: "config.max_debug_iters", value: "${config.max_debug_iters}" },
      SUBPROCESS_TIMEOUT_SEC: { when: "config.subprocess_timeout_sec", value: "${config.subprocess_timeout_sec}" },
      REFINE_TIMEOUT_SEC:     { when: "config.refine_timeout_sec",     value: "${config.refine_timeout_sec}" },
      TOTAL_BUDGET_SEC:       { when: "config.total_budget_sec",       value: "${config.total_budget_sec}" },
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8080 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      openai_api_key:         { type: "string", secret: true },
      openai_model:           { type: "string" },
      reasoning_effort:       { type: "string" },
      max_debug_iters:        { type: "string" },
      subprocess_timeout_sec: { type: "string" },
      refine_timeout_sec:     { type: "string" },
      total_budget_sec:       { type: "string" },
    },
    required: ["openai_api_key"],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
}
